# =============================================================================
# Semantic Search Layer — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Embedder
# "voyage"  — VoyageAI API (requires VOYAGE_API_KEY, higher quality for code)
# "local"   — Ollama (offline, no API key needed)
# -----------------------------------------------------------------------------
EMBEDDER_TYPE=voyage

# VoyageAI API key — required when EMBEDDER_TYPE=voyage
# Get one at https://www.voyageai.com
VOYAGE_API_KEY=

# Ollama configuration — required when EMBEDDER_TYPE=local
# Install Ollama: https://ollama.com
# Then run: ollama pull nomic-embed-text  OR  ollama pull mxbai-embed-large
OLLAMA_URL=http://localhost:11434

# Local model name. Supported options:
#   nomic-embed-text   — 768-dim, fast, good general retrieval
#   mxbai-embed-large  — 1024-dim, higher quality (same dim as voyage-code-3)
# WARNING: Changing model dimension requires deleting the collection and re-indexing:
#   qdrant collection delete → index-docs full --force → index-code full --force
LOCAL_MODEL_NAME=nomic-embed-text

# -----------------------------------------------------------------------------
# Project name — used as the Docker container name suffix (qdrant-<PROJECT_NAME>)
# Set this to your git repository folder name to avoid collisions when running
# multiple projects on the same machine.
# -----------------------------------------------------------------------------
PROJECT_NAME=my-project

# -----------------------------------------------------------------------------
# Qdrant
# http://localhost:6333  — Docker (recommended, persistent)
# :memory:               — Embedded in-process (no Docker, no persistence, CI-friendly)
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333

# API key — required only for remote/cloud Qdrant with authentication enabled
# Leave empty for local Docker (no auth)
QDRANT_API_KEY=

# Retry/backoff for transient Qdrant errors (useful for Qdrant Cloud or unstable links)
QDRANT_RETRY_ATTEMPTS=4
QDRANT_RETRY_BACKOFF_SECONDS=1.0

# Batch sizes for Qdrant lookups/upserts. Reduce if your remote instance resets connections.
QDRANT_RETRIEVE_BATCH_SIZE=128
QDRANT_UPSERT_BATCH_SIZE=64

# Collection names — defaults to "{PROJECT_NAME}_docs" and "{PROJECT_NAME}_code"
# Override only if you need custom names
# DOCS_COLLECTION=my_docs
# CODE_COLLECTION=my_code

# -----------------------------------------------------------------------------
# Indexing roots and filters
# Paths are relative to the repository root (git root, parent of .semantic-search/)
# -----------------------------------------------------------------------------
DOCS_ROOT=docs
CODE_ROOT=.   # repo root — indexes everything not excluded by INDEX_EXCLUDE

INDEX_EXTENSIONS_DOCS=.md,.yaml,.mmd
# Full list — remove extensions you don't need to keep the index lean
INDEX_EXTENSIONS_CODE=.py,.js,.jsx,.ts,.tsx,.java,.kt,.kts,.scala,.groovy,.cs,.fs,.vb,.go,.rs,.c,.h,.cpp,.cc,.cxx,.hpp,.swift,.dart,.rb,.php,.lua,.pl,.sh,.bash,.zsh,.ps1,.r,.jl,.hs,.ex,.exs,.erl,.clj

# Comma-separated directory/file names to exclude from indexing
INDEX_EXCLUDE=.git,__pycache__,.venv,node_modules,.semantic-search,qdrant_storage
